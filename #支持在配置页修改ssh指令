{
    "push_group_id": {
        "description": "推送群号",
        "type": "string",
        "hint": "接收更新通知的 QQ 群号。填好后插件启动即自动开始轮询。"
    },
    "mod_ids": {
        "description": "模组 ID 列表",
        "type": "string",
        "hint": "纯数字 ID，用逗号(,)或分号(;)隔开。支持直接从服务端 .ini 复制粘贴。"
    },
    "poll_interval_minutes": {
        "description": "轮询间隔 (分钟)",
        "type": "int",
        "hint": "建议设为 30。请求过于频繁会导致 Steam 拒绝响应。",
        "default": 30
    },
    "max_retries": {
        "description": "请求失败重试次数",
        "type": "int",
        "hint": "因网络波动请求失败时，自动重试的次数。默认 5 次。",
        "default": 5
    },
    "steam_api_base": {
        "description": "API 接口地址",
        "type": "string",
        "hint": "Steam Web API 地址。如服务器在国内连不上，可改为反代地址。",
        "default": "https://api.steampowered.com"
    },
    "steam_api_key": {
        "description": "API Key (可选)",
        "type": "string",
        "hint": "去 Steam 开发者页面申请。填入可大幅降低被限制频率的概率。"
    },
    "auto_reset_enable": {
        "description": "启用每日定时安检与重置",
        "type": "bool",
        "hint": "开启后，将在下方设定的时间进行静默健康检查，成功则清零红灯，失败则群内报警。",
        "default": false
    },
    "auto_reset_time": {
        "description": "每日定时安检时间",
        "type": "string",
        "hint": "格式如 04:20 (建议比NAS重启时间晚15-20分钟)",
        "default": "04:20"
    },
    "server_ip": {
        "description": "服务器 IP/域名",
        "type": "string",
        "hint": "用于 RCON 控制和健康探测。必须填写才能使用自动升级功能。",
        "default": ""
    },
    "server_port": {
        "description": "服务器探测/RCON端口",
        "type": "int",
        "hint": "必须是 TCP 端口。填 RCON 端口(默认 27015)，能精确判断是否开服成功。",
        "default": 27015
    },
    "server_rcon_password": {
        "description": "RCON 密码",
        "type": "string",
        "hint": "必须填写，用于读取在线玩家人数和执行安全重启指令。"
    },
    "server_rcon_broadcast": {
        "description": "有更新时(有人在线)的广播",
        "type": "string",
        "hint": "检测到更新且有玩家时发送。仅提醒，不立刻重启。",
        "default": "查询到模组有更新，不影响您本次游玩，您游戏结束1小时后会自动更新，如需要强制更新，请联系麻花！"
    },
    "server_rcon_countdown": {
        "description": "自动更新(无玩家)倒计时(秒)",
        "type": "int",
        "hint": "确认为 0 玩家时，执行保存并关机前的缓冲时间。默认 5 秒。",
        "default": 5
    },
    "server_rcon_manual_broadcast": {
        "description": "人工强制重启的警告广播",
        "type": "string",
        "hint": "群主手动发送 /steammod restart 时，在游戏内触发的全局广播。",
        "default": "服务器将在60秒后强制重启更新模组，请尽快找到安全的地方等待！"
    },
    "server_rcon_manual_countdown": {
        "description": "人工强制重启倒计时(秒)",
        "type": "int",
        "hint": "手动强制重启时，发送广播后留给玩家安全下线的逃生时间。默认 60 秒。",
        "default": 60
    },
    "server_restart_wait_minutes": {
        "description": "重启后首次探针延迟(分钟)",
        "type": "int",
        "hint": "执行重启后，等待多久再进行首次 Ping 测试。建议根据服务器实际开服速度填写。",
        "default": 6
    },
    "restart_method": {
        "description": "重启/更新执行方式",
        "type": "string",
        "hint": "选 rcon (旧版断电) 或 linuxgsm (调用Ubuntu原生重启升级指令)。",
        "default": "rcon"
    },
    "ssh_host": {
        "description": "SSH 主机 IP",
        "type": "string",
        "hint": "填入 Ubuntu 虚拟机的 IP (仅 linuxgsm 模式需填写)",
        "default": "192.168.31.49"
    },
    "ssh_port": {
        "description": "SSH 端口",
        "type": "int",
        "hint": "默认 22 (仅 linuxgsm 模式需填写)",
        "default": 22
    },
    "ssh_user": {
        "description": "SSH 用户名",
        "type": "string",
        "hint": "默认 steam (仅 linuxgsm 模式需填写)",
        "default": "steam"
    },
    "ssh_password": {
        "description": "SSH 密码",
        "type": "string",
        "hint": "steam 用户的登录密码 (仅 linuxgsm 模式需填写)"
    },
    "cmd_rcon_save": {
        "description": "自定义 RCON 保存指令",
        "type": "string",
        "hint": "执行关机前发送的保存指令。PZ默认: save",
        "default": "save"
    },
    "cmd_rcon_quit": {
        "description": "自定义 RCON 关机指令",
        "type": "string",
        "hint": "断电模式下使用的关机指令。PZ默认: quit",
        "default": "quit"
    },
    "cmd_ssh_restart": {
        "description": "自定义 SSH 重启指令",
        "type": "string",
        "hint": "LinuxGSM模式下执行的完整重启指令。",
        "default": "cd /home/steam && ./pzserver restart"
    }
}
